# Optional. Used to enrich BNB Chain and other Etherscan V2 compatible chains.
# Get one key from Etherscan, then pass chainid=56 for BNB.
ETHERSCAN_API_KEY=
BSCSCAN_API_KEY=

# Optional branding for the share card watermark.
PUBLIC_SITE_URL=https://degendna.fun
PUBLIC_SITE_HOST=degendna.fun

# Optional. Enables real X display name and profile image lookup.
# Alias supported: X_API_BEARER_TOKEN or TWITTER_BEARER_TOKEN.
X_BEARER_TOKEN=

# Optional server port.
PORT=8787
